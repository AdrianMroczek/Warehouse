pipeline {
  agent any
  environment {
    IMAGE_NAME = "warehouse-app"
    CONTAINER_NAME = "warehouse-app-container"
  }
  stages {
    stage ('Docker Build'){
      steps {
        bat "docker build -t ${IMAGE_NAME} ."
      }
    }
  stage ('Docker Run'){
    steps {
      bat "docker run -d -p 8000:8000 --name ${CONTAINER_NAME} ${IMAGE_NAME}"
      sleep time: 10, unit: 'SECONDS'
    }
  }
  stage ('Sanity Seeding Test'){
    steps {
      bat "python -m pytest tests/sanity_tests/test_seeding.py"
    }
  }
  stage ('Sanity UI Test'){
    steps {
      bat "python -m pytest tests/sanity_tests/test_UI_sanity.py"
    }
  }
}
}